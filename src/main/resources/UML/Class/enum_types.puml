@startuml
title 聊天系统 - 基础枚举类型

enum MsgReceiverType {
    USER: 单聊接收者（用户）
    GROUP: 群聊接收者（群）
}

enum MediaType {
    IMAGE: 图片
    VIDEO: 视频
}

enum GroupRole {
    OWNER: 群主
    ADMIN: 管理员
    MEMBER: 普通成员
}

enum GroupPermission {
    MANAGE_MEMBER: 管理成员（拉人/踢人）
    MODIFY_GROUP_INFO: 修改群资料
    DELETE_MSG: 删除群消息
    MUTE_MEMBER: 禁言成员
    SEND_MSG: 发送群消息
    INVITE_MEMBER: 邀请入群
}

enum RedisKeyConstant {
    USER_LAST_READ_TS: "user:lastReadTs:{userId}"
    USER_ONLINE_STATUS: "user:onlineStatus:{userId}"
    GROUP_MEMBER_ROLE: "group:member:role:{groupId}:{userId}"
    GROUP_MEMBER_MUTE: "group:member:mute:{groupId}:{userId}"
    USER_UNREAD_COUNT: "user:unreadCount:{userId}"
}

@enduml