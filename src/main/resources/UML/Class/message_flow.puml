@startuml
title 聊天系统 - 消息流转类

' 引入依赖
!include enum_types.puml
!include core_entities.puml
!include storage_interaction.puml

class MessageProducer {
    + ossClient: OSSClient  // 依赖OSS
    + hotCache: HotDataCacheService  // 依赖缓存
    + produceMsg(msg: Message, senderRole: GroupRole): Boolean  // 生成消息（含权限校验）
    + uploadMediaToOSS(mediaFile: File, mediaType: MediaType): Media  // 上传多媒体
}

class UserMessageQueue {
    + userId: String  // 关联用户
    + unreadMsgList: List<Message>  // 未读消息列表
    + enqueue(msg: Message, hotCache: HotDataCacheService): Boolean  // 入队+未读数+1
    + dequeue(msgId: String, hotCache: HotDataCacheService): Boolean  // 出队+未读数-1
    + getMsgAfterTs(ts: Long): List<Message>  // 按时间戳拉取
    + getUnreadCount(hotCache: HotDataCacheService): Int  // 查未读数
    + markMsgAsRead(msgIdList: List<String>, hotCache: HotDataCacheService): Boolean  // 批量标已读
}

class GroupMessageQueue {
    + groupId: String  // 关联群
    + msgList: List<Message>  // 群历史消息
    + broadcastMsg(msg: Message, hotCache: HotDataCacheService): Boolean  // 分发到成员队列
    + deleteMsg(msgId: String, operatorId: String, hotCache: HotDataCacheService): Boolean  // 删除消息
    + getMsgAfterTs(ts: Long): List<Message>  // 拉取历史
}

' 流转关系
MessageProducer "1" -- "1" OSSClient: 依赖（上传多媒体）
MessageProducer "1" -- "1" Message: 生成（创建消息）
MessageProducer "1" -- "*" UserMessageQueue: 推送（单聊消息入队）
MessageProducer "1" -- "1" GroupMessageQueue: 推送（群聊消息入队）
GroupMessageQueue "1" -- "*" UserMessageQueue: 分发（群消息到成员）

@enduml